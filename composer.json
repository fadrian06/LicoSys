{
  "autoload": {
    "psr-4": {
      "App\\": "app"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan-deprecation-rules": "^1.1",
    "phpstan/phpstan-strict-rules": "^1.5"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "lint": "phpstan -cphpstan.neon --no-progress",
    "lint:save": "phpstan -cphpstan.neon --no-progress --generate-baseline=storage/cache/phpstan-baseline.neon --allow-empty-baseline"
  },
  "require": {
    "faslatam/flight": "^2.0",
    "faslatam/sparrow": "^1.0"
  }
}
