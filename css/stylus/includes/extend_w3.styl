.w3-step-container
	max-width: 75%
	margin: auto
	position: relative
	display: flex
	justify-content: space-between
	&::after
		content: ''
		width: 80%
		height: 5px
		position: absolute
		top: calc(50% - 2.5px)
		transform: translateX(15%)
		z-index: 50
		background: black
		border-radius: 10px
	.w3-step
		max-width: max-content
		z-index: 51
		margin: 0 20px
		background: black
		color: white
		font-size: 1.5em
		border-radius: 50%
		padding: 2px 15px

.w3-oswald
	font-family: 'Oswald', 'Roboto', sans-serif !important
	& *
		font-family: inherit

.w3-border-scroll
	border-top-right-radius: 15px
	border-bottom-right-radius: 15px

.w3-width-100
	max-width: 100%

.w3-height-100
	min-height: 100%

.w3-width-25
	min-width: 25%

.w3-width-40
	min-width: 40%

.w3-width-50
	min-width: 50%

.w3-padding-top10
	padding-top: 10px !important

.w3-padding-right40
	padding-right: 40px !important

.w3-padding-right50
	padding-right: 50px !important

.w3-padding-0
	padding: 0 !important

.w3-margin-0
	margin: 0 !important