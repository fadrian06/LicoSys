@media screen and (max-width: 1000px)
	form#registrarNegocio
		padding-top: 20px !important

.tooltip
	position: relative
	display: inline-block !important
	border-bottom: 1px dotted black
	.tooltiptext
		visibility: hidden
		width: 120px
		background-color: #555
		color: #fff
		text-align: center
		padding: 5px 0
		border-radius: 6px
		position: absolute
		z-index: 1
		bottom: 125%
		left: 50%
		margin-left: -60px
		opacity: 0
		transition: opacity .3s
		&::after
			content: ''
			position: absolute
			top: 100%
			left: 50%
			margin-left: -5px
			border-width: 5px
			border-style: solid
			border-color: #555 transparent transparent transparent;
	&:hover .tooltiptext
		visibility: visible
		opacity: 1

*.w3-input:focus
	outline: none

*.w3-display-container
	transition: .4s ease all

.w3-modal-content
	border-radius: 20px 0 20px 20px
	max-width: max-content

.w3-main
	margin-left: 255px;
	margin-top: 43px;

@media screen and (max-width: 600px)
	#formClave .icon-eye,
	#form-Clave .icon-eye-slash
		position: absolute;
		top: -4.5px;