div.w3-modal.w3-show.w3-padding-large
	form#registrarAdmin.w3-modal-content.w3-padding-top10.w3-round-xlarge.w3-border-scroll(
		method='POST'
		enctype='multipart/form-data'
		autocomplete='off'
	)
		h1.w3-center.w3-oswald CREE SU CUENTA DE 
			b.w3-text-teal ADMINISTRADOR
		div.w3-step-container
			span.w3-step 1
			span.w3-step.w3-teal 2
		div.w3-row.w3-margin-top.w3-topbar
			div.w3-twothird.w3-rightbar.w3-bottombar
				fieldset.w3-border-0
					legend.w3-large.w3-padding
						b Cédula:
					div.w3-row.w3-border-bottom.w3-center
						div.icon-edit.w3-col.s2.w3-xxlarge.w3-teal
						div.w3-col.s8.w3-display-container
							input#cedula.w3-input.w3-border-0.w3-large(
								text='number'
								name='cedula'
								placeholder='Cédula'
								required
								minlenght='7'
								maxlenght='8'
								pattern='[^e]?\\d{7,8}'
								title='Un número entre 7 y 8 dígitos'
							)
						div.w3-rest.w3-xxlarge.w3-text-green.icon-check.w3-animate-zoom.w3-hide
						div.w3-rest.w3-xxlarge.w3-text-red.icon-close.w3-animate-zoom.w3-hide
				fieldset.w3-border-0
					legend.w3-large.w3-padding
						b Nombre:
					div.w3-row.w3-border-bottom.w3-center
						div.icon-edit.w3-col.s2.w3-xxlarge.w3-teal
						div.w3-col.s8.w3-display-container
							input#nombre.w3-input.w3-border-0.w3-large(
								name='nombre'
								placeholder='Nombre'
								autocapitalize
								required
								minlenght='4'
								maxlenght='20'
								pattern='[a-zA-ZÁáÉéÍíÓóÚúÑñ\\s]{4,20}'
								title='Sólo se permiten entre 4 y 20 letras'
							)
						div.w3-rest.w3-xxlarge.w3-text-green.icon-check.w3-animate-zoom.w3-hide
						div.w3-rest.w3-xxlarge.w3-text-red.icon-close.w3-animate-zoom.w3-hide
				fieldset.w3-border-0
					legend.w3-large.w3-padding
						b Usuario:
					div.w3-row.w3-border-bottom.w3-center
						div.icon-edit.w3-col.s2.w3-xxlarge.w3-teal
						div.w3-col.s8.w3-display-container
							input#usuario.w3-input.w3-border-0.w3-large(
								name='usuario'
								placeholder='@usuario'
								required
								minlenght='4'
								maxlength='20'
								pattern='@?[\\w-]{4,20}'
								title='Sólo se permiten entre 4 y 20 letras, números y símbolos(@ - _)'
							)
						div.w3-rest.w3-xxlarge.w3-text-green.icon-check.w3-animate-zoom.w3-hide
						div.w3-rest.w3-xxlarge.w3-text-red.icon-close.w3-animate-zoom.w3-hide
				fieldset.w3-border-0
					legend.w3-large.w3-padding
						b Nueva contraseña:
					div.w3-row.w3-border-bottom.w3-center
						div.icon-edit.w3-col.s2.w3-xxlarge.w3-teal
						div.w3-col.s8.w3-display-container
							input#nuevaClave.w3-input.w3-border-0.w3-large(
								type='password'
								name='nuevaClave'
								placeholder='Crear contraseña'
								required
								minlenght='4'
								maxlength='20'
								pattern='[\\w.-@#*]{4,20}'
								title='Sólo se permiten entre 4 y 20 letras, números y símbolos (. - _ @ # *)'
							)
						div.w3-rest.w3-xlarge.icon-eye
						div.w3-rest.w3-xxlarge.w3-text-green.icon-check.w3-animate-zoom.w3-hide
						div.w3-rest.w3-xxlarge.w3-text-red.icon-close.w3-animate-zoom.w3-hide
				fieldset.w3-border-0
					legend.w3-large.w3-padding
						b Confirmar contraseña:
					div.w3-row.w3-border-bottom.w3-center
						div.icon-edit.w3-col.s2.w3-xxlarge.w3-teal
						div.w3-col.s8.w3-display-container
							input#confirmar.w3-input.w3-border-0.w3-large(
								type='password'
								name='confirmar'
								placeholder='Repetir contraseña'
								required
								minlenght='4'
								maxlength='20'
								pattern='[\\w.-@#*]{4,20}'
								title='Sólo se permiten entre 4 y 20 letras, números y símbolos (. - _ @ # *)'
							)
						div.w3-rest.w3-xlarge.icon-eye
						div.w3-rest.w3-xxlarge.w3-text-green.icon-check.w3-animate-zoom.w3-hide
						div.w3-rest.w3-xxlarge.w3-text-red.icon-close.w3-animate-zoom.w3-hide
				fieldset.w3-border-0
					legend.w3-large.w3-padding
						b Teléfono <sub class='w3-text-blue'>(opcional)</sub>:
					div.w3-row.w3-border-bottom.w3-center
						div.icon-edit.w3-col.s2.w3-xxlarge.w3-teal
						div.w3-col.s8.w3-display-container
							input#telefono.w3-input.w3-border-0.w3-large(
								type='tel'
								name="telefono"
								placeholder='Introduce un teléfono'
								minlenght='11'
								maxlength='16'
								pattern='(0|\\+57|\\+58)[\\s-]?(412|414|424|416|426)-?\\d{3}-?\\d{4}'
								title='Ejemplos de teléfonos válidos (0416-111-1111 o +57-1119999)'
							)
						div.w3-rest.w3-xxlarge.w3-text-green.icon-check.w3-animate-zoom.w3-hide
						div.w3-rest.w3-xxlarge.w3-text-red.icon-close.w3-animate-zoom.w3-hide
				div.w3-container.w3-margin
					button.w3-button.w3-block.w3-teal.w3-round-large Registrar
						div.w3-large.w3-margin-left.icon-refresh.w3-spin.w3-hide
			div.w3-third.w3-center
				div.w3-container.w3-margin-top
					b.w3-block.w3-medium Foto de perfil
					b.w3-block.w3-small.w3-text-blue Opcional
				label(for='foto').w3-block.w3-display-container.w3-hover-opacity
					span.icon-camera.w3-xxxlarge.w3-display-middle.w3-display-hover
					img.w3-image.image-result.w3-round-large(
						src='assets/images/avatar1.png'
						style='width: 150px'
					)
				input#foto.w3-hide(type='file' name='foto' accept='.jpeg, .jpg, .png')
				label.w3-button.w3-margin.w3-teal.w3-round-large(for="foto") Sube una foto